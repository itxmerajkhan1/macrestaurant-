{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data including dietary flags and tier status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "role": { "type": "string", "enum": ["Manager", "Staff", "Citizen"] },
        "dietaryFlags": {
          "type": "object",
          "properties": {
            "halal": { "type": "boolean" },
            "vegan": { "type": "boolean" },
            "vegetarian": { "type": "boolean" },
            "noBeef": { "type": "boolean" },
            "glutenFree": { "type": "boolean" }
          }
        },
        "paymentCards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "number": { "type": "string" },
              "expiry": { "type": "string" }
            }
          }
        },
        "tier": { "type": "string", "enum": ["NEON", "CYBER", "QUANTUM"] },
        "credits": { "type": "number" },
        "orderHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "items": { "type": "array", "items": { "type": "string" } },
              "total": { "type": "number" },
              "date": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Global order tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string", "format": "email" },
        "items": { "type": "array", "items": { "type": "string" } },
        "total": { "type": "number" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Out for Delivery", "Delivered", "Cancelled"] },
        "date": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "items", "total", "status", "date"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Log of administrative actions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adminId": { "type": "string" },
        "adminEmail": { "type": "string", "format": "email" },
        "actionType": { "type": "string", "enum": ["CANCEL_ORDER", "UPDATE_ORDER_STATUS", "MODIFY_USER_DATA", "SYSTEM_REBOOT"] },
        "targetId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "adminId", "adminEmail", "actionType", "targetId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile document."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Order document."
    },
    "/admin_audit_log/{logId}": {
      "schema": "AuditLog",
      "description": "Administrative audit log document."
    }
  }
}
